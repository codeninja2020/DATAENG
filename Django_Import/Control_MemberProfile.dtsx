      DTS:ObjectName="SQL_CREATE_TABLES">
      <DTS:VariableValue
        DTS:DataType="8">/****** Object:  Table [django].[articles]    Script Date: 16/02/2020 18:33:02 ******/ SET ansi_nulls ON;  SET quoted_identifier ON;   IF NOT EXISTS (SELECT *                 FROM   sys.objects                 WHERE  object_id = Object_id(N'[django].[articles]')                        AND type IN ( N'U' ))    BEGIN        CREATE TABLE [django].[articles]          (             [id]          [INT] NOT NULL,             [title]       [NVARCHAR](4000) NULL,             [slug]        [NVARCHAR](4000) NULL,             [tags]        [NVARCHAR](4000) NULL,             [created]     [DATETIME2](0) NULL,             [inserted_on] [DATETIME] NOT NULL,             [processid]   [VARCHAR](36) NULL          )        ON [PRIMARY]    END; /****** Object:  Table [django].[brands]    Script Date: 16/02/2020 18:33:02 ******/   SET ansi_nulls ON;  SET quoted_identifier ON;   IF NOT EXISTS (SELECT *                 FROM   sys.objects                 WHERE  object_id = Object_id(N'[django].[brands]')                        AND type IN ( N'U' ))    BEGIN        CREATE TABLE [django].[brands]          (             [id]          [INT] NOT NULL,             [name]        [NVARCHAR](4000) NULL,             [vendor_id]   [INT] NULL,             [inserted_on] [DATETIME] NOT NULL,             [processid]   [VARCHAR](36) NULL          )        ON [PRIMARY]    END; /****** Object:  Table [django].[dining_celebrity_chefs]    Script Date: 16/02/2020 18:33:02 ******/   SET ansi_nulls ON;  SET quoted_identifier ON;   IF NOT EXISTS (SELECT *                 FROM   sys.objects                 WHERE  object_id = Object_id(N'[django].[dining_celebrity_chefs]'                                    )                        AND type IN ( N'U' ))    BEGIN        CREATE TABLE [django].[dining_celebrity_chefs]          (             [id]          [INT] NOT NULL,             [name]        [NVARCHAR](4000) NULL,             [inserted_on] [DATETIME] NOT NULL,             [processid]   [VAR