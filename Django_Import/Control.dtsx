      <DTS:VariableValue
        DTS:DataType="8">IF NOT EXISTS ( SELECT * FROM sys.schemas WHERE name = N'django' ) 	BEGIN 		EXEC('CREATE SCHEMA [django] AUTHORIZATION [dbo]'); 	END</DTS:VariableValue>
