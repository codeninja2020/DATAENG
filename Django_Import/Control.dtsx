        /// To open Help, press F1.
        /// </summary>
		public void Main()
		{
            // TODO: Add your code here
            Dts.Variables["User::PackageName"].Value = "Load " + Dts.Variables["System::SourceName"].Value.ToString() + ".dtsx";
            Dts.TaskResult = (int)ScriptResults.Success;
		}

