;  SET quoted_identifier ON;   IF NOT EXISTS (SELECT *                 FROM   sys.objects                 WHERE  object_id = Object_id(N'[django].[entertainment_bookings]'                                    )                        AND type IN ( N'U' ))    BEGIN        CREATE TABLE [django].[entertainment_bookings]          (             [id]                 [INT] NOT NULL,             [member_id]          [INT] NULL,             [author_id]          [INT] NULL,             [name]               [NVARCHAR](4000) NULL,             [status]             [NVARCHAR](4000) NULL,             [delivery_method_id] [INT] NULL,             [performance_id]     [INT] NULL,             [payment_status]     [NVARCHAR](4000) NULL,             [external_id]        [INT] NULL,             [provider]           [NVARCHAR](4000) NULL,             [created]            [DATETIME2](0) NULL,             [inserted_on]        [DATETIME] NOT NULL,             [processid]          [VARCHAR](36) NULL          )        ON [PRIMARY]    END; /****** Object:  Table [django].[entertainment_delivery_methods]    Script Date: 16/02/2020 18:33:02 ******/   SET ansi_nulls ON;  SET quoted_identifier ON;   IF NOT EXISTS (SELECT *                 FROM   sys.objects                 WHERE  object_id =                        Object_id(N'[django].[entertainment_delivery_methods]')                        AND type IN ( N'U' ))    BEGIN        CREATE TABLE [django].[entertainment_delivery_methods]          (             [id]             [INT] NOT NULL,             [name]           [NVARCHAR](4000) NULL,             [price_currency] [NVARCHAR](4000) NULL,             [provider]       [NVARCHAR](4000) NULL,             [inserted_on]    [DATETIME] NOT NULL,             [processid]      [VARCHAR](36) NULL          )        ON [PRIMARY]    END; /****** Object:  Table [django].[entertainment_events]    Script Date: 16/02/2020 18:33:02 ******/   SET ansi_nulls ON;  SET quoted_identifier ON;   IF NOT EXISTS (SELECT *      